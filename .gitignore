# Python
__pycache__/
*.pyc
*.pyo
.venv312/
.venv/
*.egg-info/

# Temporary files
*.tmp
*.json.tmp

# Environment variables (secrets such as the Pushover token)
.env
env.sh
*secret*

# macOS
.DS_Store

# *** Do not track state/*.json (public-release policy) ***
#   The monthly data that collect.py fetches includes personal information about vulnerability
#   reporters (third-party researchers) — names, social handles, emails, etc. — carried over from
#   MSRC credits.
#   To prevent accidentally committing and publishing third-party PII, generated state is not tracked.
#   The directory structure is preserved via state/.gitkeep (fetched data stays on your local machine).
state/*.json

# Runtime internal artifacts (regenerable, not worth keeping in history)
# Temporary output of diff.py --json (used by run_monthly.sh)
state/.diff_*.json
# notify.py edge-triggered dedup record
state/.last_notified_*.json

# Machine-generated drafts (human-edited working files, not final versions)
drafts/

# Anonymization blocklist: contains real personal/organization names, so keep it out of git.
# Track report/deny_terms.txt.example (no real names) instead.
report/deny_terms.txt

# Record of detected MSRC after-the-fact revisions (auto-generated at runtime; frozen values live in state/*.json)
state/.revisions/

# KEV/EPSS live layer (updated hourly, mutable. Separate from the frozen state. Excluded to avoid history churn)
state/enrichment.json

# Work instructions (may contain names specific to a personal environment. Keep out of the repo)
CLAUDE_CODE_*.md

# Report generation dependencies and artifacts (regenerable)
report/node_modules/
report/assets/
