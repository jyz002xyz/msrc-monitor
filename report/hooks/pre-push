#!/usr/bin/env bash
#
# pre-push hook — push 前に deny_terms のスクラブ確認を行う。
#
# ゲートが docx しか見ていなかったため、PR本文/コミットメッセージ/md source に
# 個人名 (素の given name 等) が漏れた。その再発防止。commit message と追跡ファイルを
# deny_terms (gitignore の report/deny_terms.txt) で照合し、ヒットで push を止める。
#
# インストール:  ln -sf ../../report/hooks/pre-push .git/hooks/pre-push
#   (または cp report/hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push)
#
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
# shellcheck disable=SC1091
source .venv312/bin/activate 2>/dev/null || true

if ! python report/anonymize_gate.py --check-scrub; then
  echo "" >&2
  echo "[pre-push] BLOCKED: 個人特定語がコミットメッセージ/追跡ファイルに残っています。" >&2
  echo "[pre-push] 除去してから push してください (どうしても必要なら --no-verify)。" >&2
  exit 1
fi
